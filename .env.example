# SQLite file is created beside this file unless you override the path (see Prisma docs).
DATABASE_URL="file:./dev.db"

# openssl rand -base64 32
AUTH_SECRET=

# Used by Auth.js — set to app origin locally and production URL when deployed.
AUTH_URL="http://localhost:3000"

# Dev seed — used by `npm run prisma:seed` (never use weak passwords in production).
SEED_USER_EMAIL="dev@myhoppies.local"
SEED_USER_PASSWORD="devpassword123"
